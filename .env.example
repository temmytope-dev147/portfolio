# Copy this file to .env for local development.
# On Render, set these as Environment Variables in the dashboard instead.

# Port the server listens on (Render sets this automatically — leave unset in production)
PORT=5000

# Where contact-form messages get delivered to
EMAIL_TO=qtemmytope@gmail.com

# SMTP credentials used to actually send the email (e.g. Gmail, SendGrid, Mailgun, Outlook)
# Example for Gmail: use an "App Password", not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
